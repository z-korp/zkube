# Required network selector: slot | sepolia | mainnet
VITE_PUBLIC_DEPLOY_TYPE=slot

# Slot name (required only for slot mode)
VITE_PUBLIC_SLOT=zkube-djizus-slot

# Shared app configuration
VITE_PUBLIC_NAMESPACE=zkube_budo_v1_2_0
VITE_PUBLIC_NODE_URL=https://api.cartridge.gg/x/zkube-djizus-slot/katana
VITE_PUBLIC_TORII=https://api.cartridge.gg/x/zkube-djizus-slot/torii

# Contract addresses
VITE_PUBLIC_WORLD_ADDRESS=0x...
VITE_PUBLIC_GAME_TOKEN_ADDRESS=0x...
VITE_PUBLIC_CUBE_TOKEN_ADDRESS=0x...

# Optional metagame overrides
VITE_PUBLIC_METAGAME_TORII_URL=
VITE_PUBLIC_DENSHOKAN_ADDRESS=
VITE_PUBLIC_METAGAME_NAMESPACE=
